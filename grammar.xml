<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="../print.xsl" ?>
<?xml-stylesheet type="text/css" href="../rules.css" 
title="Easy editing stylesheet" ?>
<rules lang="tl" xsi:noNamespaceSchemaLocation="../rules.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xs="http://www.w3.org/2001/XMLSchema">
	<category name="RJ's Rules">
		<rule id="TAGA_MAKA_PANTANGI" name="taga/maka (taga-/maka-)">
			<pattern case_sensitive="no" mark_from="0">
				<token regexp="yes">taga|maka</token>
				<token regexp="yes">[A-Z].*<exception>Diyos</exception></token>
			</pattern>
			<message> Do you mean <suggestion><match no="1"/>-<match no="2"/></suggestion>? Ginagamitan ng gitling ang unlaping nagtatapos sa patinig kapag ikinakabit sa pangngalang pantangi.</message>
			<short>Nawawalang Gitling</short>
			<example correction="taga-DLSU" type="incorrect">Isang <marker>taga DLSU</marker> ang nakasungkit ng ginto.</example>
			<example type="correct">Isang <marker>taga-DLSU</marker> ang nakasungkit ng ginto.</example>
		</rule>
	</category>

	<category name="Shen's Rule">
		<rule id="CT_SA_DULO" name="ct (k)">
			<pattern case_sensitive="no" mark_from="0">
				<token regexp="yes">.*ct(s)?</token>
			</pattern>
			<message> Do you mean <suggestion><match no="1" regexp_match="(?i)(.*)ct(s)?" regexp_replace="$1k$2"/></suggestion>? Ayon sa Manwal sa Masinop na Pagsusulat seksiyon 6.2, ang hiram na salita na nagtatapos sa CT ay dapat matapos sa K imbes na KT.</message>
			<short>Walang KT</short>
			<example correction="aspek" type="incorrect">Siya ay may positibong <marker>aspect</marker> sa buhay.</example>
			<example correction="aspeks" type="incorrect">Maraming <marker>aspects</marker> ang dapat tingnan.</example>
			<example type="correct">Siya ay may positibong <marker>aspek</marker> sa buhay.</example>
		</rule>
	</category>

	<category name="Shao's Rule">
		<rule id="NG_NANG_ADJ_CHECK" name="ng (nang)">
			<pattern case_sensitive="no" mark_from="2">
				<token regexp="yes">tumakbo|lumakad|nagsalita|kumain|sumulat|tumawa|nagluto|tumigil|lumaban|sumigaw|sumayaw|tumalon|umiyak</token>
				<token regexp="yes">siya|ako|ikaw|kami|kayo|sila|tayo|ito</token>
				<token>ng</token>
				<token regexp="yes">mabilis|mabagal|maayos|malakas|mahina|mabuti|marami|tahimik|mahinhin|sobra|todo</token>
			</pattern>
			<message> Do you mean <suggestion>nang</suggestion>? Gamitin ang 'nang' sa halip na 'ng' bilang pang-abay na naglalarawan sa pandiwa.</message>
			<short>Ng vs Nang</short>
			<example correction="nang" type="incorrect">Tumakbo siya <marker>ng</marker> mabilis.</example>
			<example type="correct">Tumakbo siya <marker>nang</marker> mabilis.</example>
		</rule>
	</category>
</rules>
