<?xml version="1.0" encoding="UTF-8"?>
<rules lang="tl">

    <category name="Ng vs Nang">

        <rule id="NG_NANG_ADJ_CHECK" name="Ng vs Nang with Adjectives">
            <pattern case_sensitive="no">
                <token regexp="yes">tumakbo|lumakad|nagsalita|kumain|sumulat|tumawa|nagluto|tumigil|kumatakbo|lumaban|sumigaw|tumawid|lumipat|humakbang</token>
                <token regexp="yes">siya|ako|ikaw|kami|kayo|sila|tayo</token>
                <token>ng</token>
                <token regexp="yes">mabilis|mabagal|maayos|malakas|mahina|mabuti|marami|maunti|mahinahon|maingat|matiyaga|masaya|malungkot|biglaan|dahan-dahan|tahimik|maingay</token>
            </pattern>
            <message>Gamitin ang &apos;nang&apos; sa halip na &apos;ng&apos; kapag nagbibigay-uring pang-abay sa pandiwa. Do you mean <suggestion><match no="1"/> <match no="2"/> nang <match no="4"/></suggestion>?</message>
            <short>Ng vs Nang</short>
            <example correction="Tumakbo siya nang mabilis" type="incorrect">
                <marker>Tumakbo siya ng mabilis</marker>.
            </example>
            <example type="correct">Tumakbo siya nang mabilis.</example>
            <example type="correct">Bumili siya ng magandang damit.</example>
        </rule>

    </category>

</rules>